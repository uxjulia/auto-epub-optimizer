FROM debian:bookworm-slim

RUN apt-get update \
    && apt-get install -y --no-install-recommends inotify-tools \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY scripts/epub-watcher.sh scripts/load-env.sh scripts/

RUN chmod +x scripts/epub-watcher.sh scripts/load-env.sh

CMD ["bash", "scripts/epub-watcher.sh"]
