# epub-optimizer configuration
# Copy this file to ~/.config/epub-optimizer/.env and edit the values for your setup.
#
#   mkdir -p ~/.config/epub-optimizer
#   cp .env.example ~/.config/epub-optimizer/.env

# === Paths ===

# Folder to drop .epub files into for processing. The script will move processed files to BOOKDROP_DIR/processed/.
BOOKDROP_DIR=/path/to/main/epub/drop/folder

# Optional second drop folder for optimize-only processing.
# Files dropped here skip the Calibre copy step and only go through optimization.
# OPTIMIZE_ONLY_DIR=/path/to/optimize-only/drop/folder

# Calibre Content Server watch folder — files are copied here for Calibre to pick up.
# Leave blank or remove this line if you're not using Calibre.
CALIBRE_WATCH_FOLDER=/path/to/calibre/watch/folder

# Python executable used to run the optimizer. This can point to a virtualenv Python.
OPTIMIZER_PYTHON=python3

# Path to optimize.py — use the path where you cloned the repo.
OPTIMIZER_SCRIPT=<path/to/this/repo>/cli/optimize.py

# Where the optimizer writes finished EPUBs (epub-watcher picks them up from here and moves them).
EPUB_OUTPUT_DIR=/path/to/optimizer/output/folder

# Where epub-watcher moves finished EPUBs
WATCHER_DEST_DIR=/path/to/optimized/epub/destination/folder

# === Log files ===
OPTIMIZER_LOG_FILE=$HOME/.local/log/epub-optimizer.log
WATCHER_LOG_FILE=$HOME/.local/log/epub-watcher.log

# === Tuning ===

# Seconds between bookdrop scans.
POLL_INTERVAL=5

# Days to keep processed EPUBs in bookdrop/processed/ before auto-deletion.
KEEP_DAYS=5

# Optional epubkit pipeline settings
# EPUB_QUALITY=70
# EPUB_MAX_WIDTH=800
# EPUB_MAX_HEIGHT=480
# EPUB_CONTRAST=1.5
# EPUB_NO_GRAYSCALE=1
# EPUB_NO_CONTRAST=1
# EPUB_NO_REMOVE_FONTS=1
# EPUB_NO_REMOVE_CSS=1
# EPUB_LIGHT_NOVEL=1
# EPUB_FILENAME_FORMAT=author-title
# EPUB_SUFFIX=-optimized
